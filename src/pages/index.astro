---
import BaseLayout from '../layouts/BaseLayout.astro';
import indexData from '../data/index.json';

const stateFiles = import.meta.glob('../data/states/*.json', { eager: true });
const liveSlugs = new Set(Object.values(stateFiles).map((m: any) => m.default.stateSlug));

const title       = 'Salary by State & Job: Wages for Every Occupation in Every State';
const description = 'Find salary data by state or by job title. Nurse, teacher, developer, and 800+ more occupations in all 50 states. Official wage survey data, free.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'StateWages',
  url: 'https://statewages.com',
  description,
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>

  <section class="hero">
    <div class="container">
      <h1 class="hero-title">See what any job pays in any state</h1>
      <p class="hero-one">Wage data for 800+ jobs in all 50 states. No signup, just pick a state or search for a job below.</p>
      <div class="hero-actions">
        <a href="#states" class="btn btn-primary btn-lg">Browse by state</a>
        <a href="#occupations" class="btn btn-outline btn-lg">Browse by job</a>
      </div>
    </div>
  </section>

  <main id="main-content">
    <div class="container">

      <section id="states" class="section section-states" aria-labelledby="states-heading">
        <h2 id="states-heading" class="section-title">By state</h2>
        <p class="section-desc">Click a state to see median pay for every occupation.</p>
        <div class="state-grid">
          {indexData.states.map((s) => {
            const hasData = liveSlugs.has(s.slug);
            return (
              <a
                href={hasData ? `/salaries/${s.slug}/` : undefined}
                class={`state-card ${!hasData ? 'state-card--coming' : ''}`}
                aria-disabled={!hasData ? 'true' : undefined}
              >
                <span class="state-abbr">{s.abbreviation}</span>
                <span class="state-name">{s.name}</span>
                {!hasData && <span class="state-soon">Soon</span>}
              </a>
            );
          })}
        </div>
      </section>

      <section id="occupations" class="section section-occ" aria-labelledby="occ-heading">
        <h2 id="occ-heading" class="section-title">By job</h2>
        <p class="section-desc">Search or scroll. Click any job to see pay in every state.</p>
        <div class="occ-search-wrap">
          <label for="occ-search" class="occ-search-label">Search jobs</label>
          <input
            type="search"
            id="occ-search"
            class="occ-search-input"
            placeholder="e.g. nurse, teacher, electrician, developer"
            autocomplete="off"
            aria-describedby="occ-results-desc"
          />
          <span id="occ-results-desc" class="occ-search-hint" aria-live="polite">Results update as you type.</span>
        </div>
        <div id="occ-list" class="occ-grid">
          {indexData.occupations.map((occ) => (
            <a
              href={`/salaries/${occ.slug}/`}
              class="occ-card"
              data-occ-title={occ.title.toLowerCase()}
            >
              <span class="occ-title">{occ.title}</span>
              <span class="occ-code">SOC {occ.socCode}</span>
            </a>
          ))}
        </div>
        <p id="occ-no-results" class="occ-no-results" hidden role="status">No jobs match. Try different words.</p>
      </section>

      <div class="alert alert-info" role="note">
        All figures from the most current federal occupational wage survey. <a href="/about/">How we get the data</a> · <a href="/blog/">Blog</a>
      </div>

    </div>
  </main>
</BaseLayout>

<script>
  (function () {
    const search = document.getElementById('occ-search');
    const list = document.getElementById('occ-list');
    const noResults = document.getElementById('occ-no-results');
    const hint = document.getElementById('occ-results-desc');
    if (!search || !list || !noResults) return;

    const cards = list.querySelectorAll('[data-occ-title]');
    function filter() {
      const q = (search.value || '').trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const title = (card.getAttribute('data-occ-title') || '');
        const show = !q || title.includes(q);
        (card as HTMLElement).style.display = show ? '' : 'none';
        if (show) visible++;
      });
      noResults.hidden = visible > 0 || !q;
      if (hint) {
        if (q) hint.textContent = visible + ' job' + (visible !== 1 ? 's' : '') + ' match.';
        else hint.textContent = 'Results update as you type.';
      }
    }
    search.addEventListener('input', filter);
    search.addEventListener('search', filter);
  })();
</script>

<style>
  .hero {
    background: var(--bg-inset);
    border-bottom: 1px solid var(--border);
    padding: 2.5rem 0 2rem;
  }
  .hero-title {
    font-size: clamp(1.6rem, 3.5vw, 2.25rem);
    margin-bottom: 0.5rem;
  }
  .hero-one {
    color: var(--text-muted);
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .section-title { font-size: 1.25rem; margin-bottom: 0.25rem; }
  .section-desc { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1rem; }
  .section-states { margin-bottom: 2.5rem; }
  .section-occ { margin-bottom: 2rem; }

  .occ-search-wrap { margin-bottom: 1rem; }
  .occ-search-label {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 0.35rem;
    color: var(--text);
  }
  .occ-search-input {
    width: 100%;
    max-width: 360px;
    padding: 0.65rem 0.9rem;
    font-size: 1rem;
    font-family: var(--font);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--white);
  }
  .occ-search-input:focus {
    outline: none;
    border-color: var(--primary);
  }
  .occ-search-hint { display: block; font-size: 0.8rem; color: var(--text-faint); margin-top: 0.35rem; }

  .state-card--coming { opacity: 0.5; cursor: default; pointer-events: none; }
  .state-soon { font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-faint); margin-left: auto; }

  .occ-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.5rem;
  }
  .occ-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.65rem 0.85rem;
    text-decoration: none;
    display: block;
    transition: border-color 0.12s, background 0.12s;
  }
  .occ-card:hover {
    border-color: var(--primary);
    background: var(--primary-light);
  }
  .occ-title { display: block; font-weight: 500; font-size: 0.875rem; color: var(--primary); margin-bottom: 0.1rem; }
  .occ-code { font-size: 0.7rem; color: var(--text-faint); }
  .occ-no-results { color: var(--text-muted); font-size: 0.9rem; padding: 1rem 0; }

  @media (max-width: 640px) {
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; justify-content: center; }
    .occ-grid { grid-template-columns: 1fr; }
  }
</style>
