---
import BaseLayout from '../layouts/BaseLayout.astro';
import indexData from '../data/index.json';
import categoriesJson from '../data/occupation-categories.json';

const categories = categoriesJson as Record<string, string>;
const stateFiles = import.meta.glob('../data/states/*.json', { eager: true });
const liveSlugs = new Set(Object.values(stateFiles).map((m: any) => m.default.stateSlug));

const allCategories = [...new Set(Object.values(categories))].sort();
const title       = 'Salary by State & Job — Wages for Every Occupation in Every State';
const description = 'Find salary data by state or by job title. Nurse, teacher, developer, and 800+ more occupations in all 50 states. Official wage survey data, free.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'StateWages',
  url: 'https://statewages.com',
  description,
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: 'https://statewages.com/#occupations?q={search_term}' },
    'query-input': 'required name=search_term',
  },
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>

  <!-- Minimal hero: find jobs and states first -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">See what any job pays in any state</h1>
      <p class="hero-one">Real wage data for nurses, teachers, developers, and 800+ other jobs in all 50 states. No signup, no surveys—just the numbers.</p>

      <div class="hero-search-wrap">
        <label for="occ-search" class="visually-hidden">Search occupations</label>
        <input
          type="search"
          id="occ-search"
          class="hero-search"
          placeholder="Search jobs (e.g. nurse, developer, teacher)"
          autocomplete="off"
          aria-describedby="search-hint"
        />
        <span id="search-hint" class="hero-search-hint">Type to filter the list below</span>
      </div>

      <div class="hero-actions">
        <a href="#states" class="btn btn-primary btn-lg">Pick a state</a>
        <a href="#occupations" class="btn btn-outline btn-lg">Pick a job</a>
      </div>
    </div>
  </section>

  <main id="main-content">
    <div class="container">

      <!-- States first -->
      <section id="states" class="section section-states" aria-labelledby="states-heading">
        <h2 id="states-heading" class="section-title">By state</h2>
        <p class="section-desc">Pick a state to see median pay for every occupation.</p>
        <div class="state-grid">
          {indexData.states.map((s) => {
            const hasData = liveSlugs.has(s.slug);
            return (
              <a
                href={hasData ? `/salaries/${s.slug}/` : undefined}
                class={`state-card ${!hasData ? 'state-card--coming' : ''}`}
                aria-disabled={!hasData ? 'true' : undefined}
              >
                <span class="state-abbr">{s.abbreviation}</span>
                <span class="state-name">{s.name}</span>
                {!hasData && <span class="state-soon">Soon</span>}
              </a>
            );
          })}
        </div>
      </section>

      <!-- Occupations with client-side filter -->
      <section id="occupations" class="section section-occ" aria-labelledby="occ-heading">
        <h2 id="occ-heading" class="section-title">By occupation</h2>
        <p class="section-desc">Click any job to see pay in every state. Filter by type below.</p>
        <div class="category-filter" role="group" aria-label="Filter jobs by category">
          <span class="category-filter-label">Show:</span>
          <select id="category-select" class="category-select" aria-label="Filter by job category">
            <option value="">All jobs</option>
            {allCategories.map((cat) => (
              <option value={cat}>{cat}</option>
            ))}
          </select>
        </div>
        <div id="occ-list" class="occ-grid">
          {indexData.occupations.map((occ) => {
            const cat = categories[occ.slug] || 'other';
            return (
              <a
                href={`/salaries/${occ.slug}/`}
                class="occ-card"
                data-occ-title={occ.title.toLowerCase()}
                data-occ-category={cat}
                data-occ-slug={occ.slug}
              >
                <span class="occ-category-tag" aria-hidden="true">{cat}</span>
                <span class="occ-title">{occ.title}</span>
                <span class="occ-code">SOC {occ.socCode}</span>
              </a>
            );
          })}
        </div>
        <p id="occ-no-results" class="occ-no-results" hidden role="status">No jobs match your search. Try different words or another category.</p>
      </section>

      <div class="alert alert-info" role="note">
        All figures from the most current federal occupational wage survey. <a href="/about/">How we get the data</a> · <a href="/blog/">Blog</a>
      </div>

    </div>
  </main>
</BaseLayout>

<script>
  (function () {
    const search = document.getElementById('occ-search');
    const list = document.getElementById('occ-list');
    const noResults = document.getElementById('occ-no-results');
    if (!search || !list || !noResults) return;

    const cards = list.querySelectorAll('[data-occ-title]');
    const categorySelect = document.getElementById('category-select');
    function filter() {
      const q = (search.value || '').trim().toLowerCase();
      const cat = (categorySelect as HTMLSelectElement)?.value || '';
      let visible = 0;
      cards.forEach((card) => {
        const title = (card.getAttribute('data-occ-title') || '');
        const cardCat = card.getAttribute('data-occ-category') || '';
        const matchSearch = !q || title.includes(q);
        const matchCat = !cat || cardCat === cat;
        const show = matchSearch && matchCat;
        (card as HTMLElement).style.display = show ? '' : 'none';
        if (show) visible++;
      });
      noResults.hidden = visible > 0 || (!q && !cat);
    }
    search.addEventListener('input', filter);
    search.addEventListener('search', filter);
    if (categorySelect) categorySelect.addEventListener('change', filter);
  })();
</script>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    border: 0;
  }

  .hero {
    background: var(--bg-inset);
    border-bottom: 1px solid var(--border);
    padding: 2.5rem 0 2rem;
  }
  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 0.4rem;
  }
  .hero-one {
    color: var(--text-muted);
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }
  .hero-search-wrap {
    max-width: 420px;
    margin-bottom: 1.25rem;
  }
  .hero-search {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-family: var(--font);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--white);
  }
  .hero-search:focus {
    outline: none;
    border-color: var(--primary);
  }
  .hero-search-hint {
    display: block;
    font-size: 0.8rem;
    color: var(--text-faint);
    margin-top: 0.35rem;
  }
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .category-filter {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .category-filter-label { font-size: 0.85rem; color: var(--text-muted); }
  .category-select {
    padding: 0.4rem 0.75rem;
    font-family: var(--font);
    font-size: 0.9rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--white);
  }
  .occ-category-tag {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-faint);
    margin-bottom: 0.25rem;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    margin-bottom: 0.25rem;
  }
  .section-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .section-states { margin-bottom: 2.5rem; }
  .section-occ { margin-bottom: 2rem; }

  .state-card--coming { opacity: 0.5; cursor: default; pointer-events: none; }
  .state-soon { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-faint); margin-left: auto; }

  .occ-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.5rem;
  }
  .occ-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.65rem 0.85rem;
    text-decoration: none;
    display: block;
    transition: border-color 0.12s, background 0.12s;
  }
  .occ-card:hover {
    border-color: var(--primary);
    background: var(--primary-light);
  }
  .occ-title {
    display: block;
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--primary);
    margin-bottom: 0.1rem;
  }
  .occ-code {
    font-size: 0.7rem;
    color: var(--text-faint);
  }
  .occ-no-results {
    color: var(--text-muted);
    font-size: 0.9rem;
    padding: 1rem 0;
  }

  @media (max-width: 640px) {
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; justify-content: center; }
    .occ-grid { grid-template-columns: 1fr; }
  }
</style>
