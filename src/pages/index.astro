---
import BaseLayout from '../layouts/BaseLayout.astro';
import StateList from '../components/StateList.astro';
import businessTypes from '../data/business-types.json';
import states from '../data/states.json';

const title = 'Business License Requirements by State — 2026 Guide';
const description =
  'Find business licensing requirements for all 50 states. Fees, required documents, issuing agencies, and step-by-step application guides for every business type.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Business License Guide',
  url: 'https://businesslicenseguide.com',
  description,
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <span class="eyebrow">Free · Updated 2026 · All 50 States</span>
          <h1>The U.S. Business<br/>License Reference</h1>
          <p class="hero-lead">
            Official licensing requirements, fees, and step-by-step application
            guides for every state and business type — in one place.
          </p>
          <div class="hero-actions">
            <a href="#states" class="btn btn-primary btn-lg">Browse by State</a>
            <a href="/licenses/" class="btn btn-outline btn-lg">Browse by License Type</a>
          </div>
        </div>
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-num">{states.length}</span>
            <span class="stat-label">States</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-num">{businessTypes.length}+</span>
            <span class="stat-label">Business Types</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-num">Free</span>
            <span class="stat-label">Always</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works strip -->
  <section class="how-strip">
    <div class="container">
      <ol class="how-list">
        <li>
          <span class="how-num">01</span>
          <div>
            <strong>Pick your state</strong>
            <p>Select where your business will operate.</p>
          </div>
        </li>
        <li>
          <span class="how-num">02</span>
          <div>
            <strong>Choose your business type</strong>
            <p>Find your specific license category.</p>
          </div>
        </li>
        <li>
          <span class="how-num">03</span>
          <div>
            <strong>Follow the steps</strong>
            <p>Use our guide with direct links to official agencies.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <main>
    <div class="container">

      <!-- States -->
      <StateList />

      <!-- Business Types -->
      <section id="business-types" class="section">
        <div class="section-heading">
          <h2>Browse by License Type</h2>
          <span class="section-count">{businessTypes.length} types</span>
        </div>
        <div class="biz-type-grid">
          {businessTypes.map((bt) => (
            <a href={`/licenses/${bt.slug}/`} class="biz-type-card">
              <div class="biz-type-name">{bt.name}</div>
              <div class="biz-type-desc">{bt.description}</div>
              <span class="biz-type-cta">All states →</span>
            </a>
          ))}
        </div>
      </section>

      <div class="alert alert-info">
        <strong>Note:</strong> Requirements vary by state, county, and city.
        Always confirm details with the official issuing agency before applying.
      </div>

    </div>
  </main>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--bg-inset);
    border-bottom: 1px solid var(--border);
    padding: 4rem 0 3rem;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: end;
  }

  .hero-text .eyebrow { margin-bottom: 0.85rem; }

  .hero-text h1 {
    margin-bottom: 0.85rem;
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.1;
  }

  .hero-lead {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 500px;
    margin-bottom: 1.75rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--white);
    overflow: hidden;
    min-width: 160px;
    flex-shrink: 0;
    align-self: start;
  }

  .stat-item {
    padding: 1.1rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .stat-num {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--primary);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--text-faint);
  }

  .stat-divider {
    height: 1px;
    background: var(--border);
  }

  /* How strip */
  .how-strip {
    background: var(--white);
    border-bottom: 1px solid var(--border);
    padding: 1.5rem 0;
  }

  .how-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0;
  }

  .how-list li {
    flex: 1;
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 0.75rem 1.5rem 0.75rem 0;
    margin: 0;
    border-right: 1px solid var(--border);
  }
  .how-list li:last-child { border-right: none; padding-right: 0; }
  .how-list li:first-child { padding-left: 0; }

  .how-num {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--border-dark);
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  .how-list strong { display: block; font-size: 0.875rem; margin-bottom: 0.15rem; }
  .how-list p { font-size: 0.8rem; color: var(--text-muted); margin: 0; }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; gap: 1.75rem; }
    .hero-stats { flex-direction: row; min-width: auto; }
    .stat-divider { width: 1px; height: auto; }
    .how-list { flex-direction: column; gap: 0.75rem; }
    .how-list li { border-right: none; border-bottom: 1px solid var(--border); padding: 0 0 0.75rem; }
    .how-list li:last-child { border-bottom: none; padding-bottom: 0; }
  }
</style>
