---
import BaseLayout from '../layouts/BaseLayout.astro';
import indexData from '../data/index.json';

const stateFiles = import.meta.glob('../data/states/*.json', { eager: true });
const liveSlugs = new Set(Object.values(stateFiles).map((m: any) => m.default.stateSlug));

const title       = 'Salary by State & Occupation — StateWages';
const description = 'Look up salary data by state or by job. 800+ occupations, all 50 states. Official survey data, free.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'StateWages',
  url: 'https://statewages.com',
  description,
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>

  <!-- Minimal hero: find jobs and states first -->
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">Find salary by state or job</h1>
      <p class="hero-one">Official wage data for 800+ occupations in all 50 states. Free, no signup.</p>

      <div class="hero-search-wrap">
        <label for="occ-search" class="visually-hidden">Search occupations</label>
        <input
          type="search"
          id="occ-search"
          class="hero-search"
          placeholder="Search jobs (e.g. nurse, developer, teacher)"
          autocomplete="off"
          aria-describedby="search-hint"
        />
        <span id="search-hint" class="hero-search-hint">Type to filter the list below</span>
      </div>

      <div class="hero-actions">
        <a href="#states" class="btn btn-primary btn-lg">Browse by state</a>
        <a href="#occupations" class="btn btn-outline btn-lg">Browse by occupation</a>
      </div>
    </div>
  </section>

  <main id="main-content">
    <div class="container">

      <!-- States first -->
      <section id="states" class="section section-states">
        <h2 class="section-title">By state</h2>
        <p class="section-desc">Pick a state to see median pay for every occupation.</p>
        <div class="state-grid">
          {indexData.states.map((s) => {
            const hasData = liveSlugs.has(s.slug);
            return (
              <a
                href={hasData ? `/salaries/${s.slug}/` : undefined}
                class={`state-card ${!hasData ? 'state-card--coming' : ''}`}
                aria-disabled={!hasData ? 'true' : undefined}
              >
                <span class="state-abbr">{s.abbreviation}</span>
                <span class="state-name">{s.name}</span>
                {!hasData && <span class="state-soon">Soon</span>}
              </a>
            );
          })}
        </div>
      </section>

      <!-- Occupations with client-side filter -->
      <section id="occupations" class="section section-occ">
        <h2 class="section-title">By occupation</h2>
        <p class="section-desc">Click any job to see pay in every state.</p>
        <div id="occ-list" class="occ-grid">
          {indexData.occupations.map((occ) => (
            <a href={`/salaries/${occ.slug}/`} class="occ-card" data-occ-title={occ.title.toLowerCase()} data-occ-slug={occ.slug}>
              <span class="occ-title">{occ.title}</span>
              <span class="occ-code">SOC {occ.socCode}</span>
            </a>
          ))}
        </div>
        <p id="occ-no-results" class="occ-no-results" hidden>No jobs match your search. Try different words.</p>
      </section>

      <div class="alert alert-info">
        Data from the most current federal occupational wage survey. <a href="/about/">About the data</a> · <a href="/blog/">Blog</a>
      </div>

    </div>
  </main>
</BaseLayout>

<script>
  (function () {
    const search = document.getElementById('occ-search');
    const list = document.getElementById('occ-list');
    const noResults = document.getElementById('occ-no-results');
    if (!search || !list || !noResults) return;

    const cards = list.querySelectorAll('[data-occ-title]');
    function filter() {
      const q = (search.value || '').trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const title = (card.getAttribute('data-occ-title') || '');
        const show = !q || title.includes(q);
        (card as HTMLElement).style.display = show ? '' : 'none';
        if (show) visible++;
      });
      noResults.hidden = visible > 0 || !q;
    }
    search.addEventListener('input', filter);
    search.addEventListener('search', filter);
  })();
</script>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    border: 0;
  }

  .hero {
    background: var(--bg-inset);
    border-bottom: 1px solid var(--border);
    padding: 2.5rem 0 2rem;
  }
  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 0.4rem;
  }
  .hero-one {
    color: var(--text-muted);
    font-size: 1rem;
    margin-bottom: 1.5rem;
  }
  .hero-search-wrap {
    max-width: 420px;
    margin-bottom: 1.25rem;
  }
  .hero-search {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-family: var(--font);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--white);
  }
  .hero-search:focus {
    outline: none;
    border-color: var(--primary);
  }
  .hero-search-hint {
    display: block;
    font-size: 0.8rem;
    color: var(--text-faint);
    margin-top: 0.35rem;
  }
  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    margin-bottom: 0.25rem;
  }
  .section-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .section-states { margin-bottom: 2.5rem; }
  .section-occ { margin-bottom: 2rem; }

  .state-card--coming { opacity: 0.5; cursor: default; pointer-events: none; }
  .state-soon { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-faint); margin-left: auto; }

  .occ-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.5rem;
  }
  .occ-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.65rem 0.85rem;
    text-decoration: none;
    display: block;
    transition: border-color 0.12s, background 0.12s;
  }
  .occ-card:hover {
    border-color: var(--primary);
    background: var(--primary-light);
  }
  .occ-title {
    display: block;
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--primary);
    margin-bottom: 0.1rem;
  }
  .occ-code {
    font-size: 0.7rem;
    color: var(--text-faint);
  }
  .occ-no-results {
    color: var(--text-muted);
    font-size: 0.9rem;
    padding: 1rem 0;
  }

  @media (max-width: 640px) {
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; justify-content: center; }
    .occ-grid { grid-template-columns: 1fr; }
  }
</style>
