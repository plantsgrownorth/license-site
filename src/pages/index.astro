---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import indexData from '../data/index.json';

// Load state files to determine which have data
const stateFiles = import.meta.glob('../data/states/*.json', { eager: true });
const liveSlugs = new Set(Object.values(stateFiles).map((m: any) => m.default.stateSlug));

const title       = 'StateWages — Salary Data for Every Job in Every State (2024)';
const description = 'Free salary data for 800+ occupations across all 50 states. Median wages, percentile ranges, and employment counts sourced directly from the U.S. Bureau of Labor Statistics.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'StateWages',
  url: 'https://statewages.com',
  description,
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <span class="eyebrow">Free · BLS OEWS 2024 · All 50 States</span>
          <h1>What Does That Job<br/>Pay in Your State?</h1>
          <p class="hero-lead">
            Median wages, percentile ranges, and employment figures
            for 800+ occupations across all 50 states — drawn directly
            from official Bureau of Labor Statistics data.
          </p>
          <div class="hero-actions">
            <a href="#states" class="btn btn-primary btn-lg">Browse by State</a>
            <a href="#occupations" class="btn btn-outline btn-lg">Browse by Occupation</a>
          </div>
        </div>
        <div class="hero-stat-card">
          <div class="hsc-row">
            <span class="hsc-num">800+</span>
            <span class="hsc-label">Occupations covered</span>
          </div>
          <div class="hsc-divider"></div>
          <div class="hsc-row">
            <span class="hsc-num">51</span>
            <span class="hsc-label">States + DC</span>
          </div>
          <div class="hsc-divider"></div>
          <div class="hsc-row">
            <span class="hsc-num">BLS</span>
            <span class="hsc-label">Official U.S. government data</span>
          </div>
          <div class="hsc-divider"></div>
          <div class="hsc-row">
            <span class="hsc-num">Free</span>
            <span class="hsc-label">No account required</span>
          </div>
        </div>
      </div>
    </div>
  </section>


  <main>
    <div class="container">

      <!-- States -->
      <section id="states" class="section">
        <div class="section-heading">
          <h2>Browse by State</h2>
          <span class="section-count">{indexData.states.length} states</span>
        </div>
        <div class="state-grid">
          {indexData.states.map((s) => {
            const hasData = liveSlugs.has(s.slug);
            return (
              <a
                href={hasData ? `/salaries/${s.slug}/` : undefined}
                class={`state-card ${!hasData ? 'state-card--coming' : ''}`}
                aria-disabled={!hasData ? 'true' : undefined}
              >
                <span class="state-abbr">{s.abbreviation}</span>
                <span class="state-name">{s.name}</span>
                {!hasData && <span class="state-soon">Soon</span>}
              </a>
            );
          })}
        </div>
      </section>

      <!-- Occupations -->
      <section id="occupations" class="section">
        <div class="section-heading">
          <h2>Browse by Occupation</h2>
          <span class="section-count">{indexData.occupations.length} listed</span>
        </div>
        <div class="occ-grid">
          {indexData.occupations.map((occ) => (
            <a href={`/salaries/${occ.slug}/`} class="occ-card">
              <div class="occ-title">{occ.title}</div>
              <div class="occ-code">SOC {occ.socCode}</div>
            </a>
          ))}
        </div>
      </section>

      <div class="alert alert-info">
        <strong>Source:</strong> All data is from the U.S. Bureau of Labor Statistics, Occupational Employment and Wage Statistics (OEWS) program, May 2024. Data is updated annually.
      </div>

    </div>
  </main>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--bg-inset);
    border-bottom: 1px solid var(--border);
    padding: 4.5rem 0 3.5rem;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: center;
  }

  .hero-text h1 { margin-bottom: 0.85rem; font-size: clamp(2rem, 5vw, 3.25rem); line-height: 1.08; }
  .hero-lead { font-size: 1.05rem; color: var(--text-muted); max-width: 480px; margin-bottom: 1.75rem; line-height: 1.7; }
  .hero-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .hero-stat-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--white);
    overflow: hidden;
    min-width: 200px;
    flex-shrink: 0;
  }
  .hsc-row { padding: 1rem 1.4rem; }
  .hsc-num { display: block; font-family: var(--font-serif); font-size: 1.9rem; font-weight: 600; color: var(--primary); line-height: 1; margin-bottom: 0.15rem; }
  .hsc-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-faint); font-weight: 500; }
  .hsc-divider { height: 1px; background: var(--border); }


  /* State grid – extend with coming-soon */
  .state-card--coming { opacity: 0.5; cursor: default; pointer-events: none; }
  .state-soon { font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-faint); margin-left: auto; }

  /* Occupation grid */
  .occ-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.6rem; }
  .occ-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.75rem 0.9rem;
    text-decoration: none;
    display: block;
    transition: border-color 0.12s;
  }
  .occ-card:hover { border-color: var(--primary); }
  .occ-title { font-weight: 500; font-size: 0.875rem; color: var(--primary); margin-bottom: 0.15rem; }
  .occ-code { font-size: 0.72rem; color: var(--text-faint); font-family: var(--font-mono, monospace); }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 2rem; }
    .feature-list { grid-template-columns: 1fr; gap: 1.25rem; }
  }
</style>
