---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const title = 'Contact Us - Business License Guide';
const description =
  'Contact Business License Guide with questions, corrections, or requests for new license information. We welcome feedback from entrepreneurs and business owners.';
---

<BaseLayout title={title} description={description}>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />

  <div class="page-hero">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Have a question, found an error, or want to request a new license guide? We'd love to hear from you.</p>
    </div>
  </div>

  <main>
    <div class="container">
      <div class="contact-layout">

        <div class="contact-form-wrap">
          <h2>Send a Message</h2>
          <p class="form-intro">
            Fill out the form below and we'll get back to you as soon as possible.
            We typically respond within 2–3 business days.
          </p>

          <form class="contact-form" name="contact" method="POST" data-netlify="true" action="/contact/success/">
            <input type="hidden" name="form-name" value="contact" />

            <div class="form-row">
              <div class="form-group">
                <label for="name">Your Name <span class="required">*</span></label>
                <input type="text" id="name" name="name" required placeholder="Jane Smith" />
              </div>
              <div class="form-group">
                <label for="email">Email Address <span class="required">*</span></label>
                <input type="email" id="email" name="email" required placeholder="jane@example.com" />
              </div>
            </div>

            <div class="form-group">
              <label for="subject">Subject <span class="required">*</span></label>
              <select id="subject" name="subject" required>
                <option value="" disabled selected>Select a topic</option>
                <option value="correction">Report an Error / Outdated Info</option>
                <option value="request">Request a New License Guide</option>
                <option value="general">General Question</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-group">
              <label for="state">State (if applicable)</label>
              <input type="text" id="state" name="state" placeholder="e.g., California" />
            </div>

            <div class="form-group">
              <label for="message">Message <span class="required">*</span></label>
              <textarea id="message" name="message" required placeholder="Please describe your question or request in detail..."></textarea>
            </div>

            <button type="submit" class="btn btn-primary btn-lg">Send Message</button>
          </form>
        </div>

        <aside class="contact-sidebar">
          <div class="info-block">
            <h3>Common Reasons to Contact Us</h3>
            <ul class="contact-reasons">
              <li>
                <span class="reason-icon">🔍</span>
                <div>
                  <strong>Report Outdated Info</strong>
                  <p>Let us know if a fee, requirement, or agency link has changed.</p>
                </div>
              </li>
              <li>
                <span class="reason-icon">➕</span>
                <div>
                  <strong>Request a New Guide</strong>
                  <p>We prioritize states and business types based on user requests.</p>
                </div>
              </li>
              <li>
                <span class="reason-icon">❓</span>
                <div>
                  <strong>General Questions</strong>
                  <p>Questions about how to use the site or interpret the information.</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="info-block">
            <h3>Please Note</h3>
            <p style="font-size: 0.875rem; color: var(--color-text-muted); margin: 0;">
              We provide informational content only and cannot provide legal or professional advice.
              For specific legal questions about your business, please consult a licensed attorney.
            </p>
          </div>
        </aside>

      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2.5rem;
    align-items: start;
    padding: 2.5rem 0;
  }

  .contact-form-wrap h2 {
    margin-bottom: 0.5rem;
  }

  .form-intro {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1.75rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .required {
    color: #dc2626;
  }

  .contact-reasons {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-reasons li {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    margin: 0;
  }

  .reason-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .contact-reasons strong {
    display: block;
    font-size: 0.875rem;
    margin-bottom: 0.2rem;
  }

  .contact-reasons p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
