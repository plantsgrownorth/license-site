---
import BaseLayout from '../layouts/BaseLayout.astro';

const CONTACT_EMAIL = 'arjungoel42@gmail.com';

const title = 'Contact StateWages';
const description = 'Get in touch with StateWages. Questions about the data, corrections, or feedback.';
---

<BaseLayout title={title} description={description}>
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">Contact</span>
      <h1>Get in touch</h1>
      <p>Questions about the data, spot a typo or wrong number, or just want to say hi. We read everything.</p>
    </div>
  </div>

  <main>
    <div class="container">
      <div class="contact-layout">
        <div class="contact-form-wrap">
          <form class="contact-form" id="contact-form" novalidate>
            <div class="form-group">
              <label for="contact-name">Name</label>
              <input type="text" id="contact-name" name="name" required placeholder="Your name" />
            </div>
            <div class="form-group">
              <label for="contact-email">Your email</label>
              <input type="email" id="contact-email" name="email" required placeholder="you@example.com" />
            </div>
            <div class="form-group">
              <label for="contact-message">Message</label>
              <textarea id="contact-message" name="message" required rows="5" placeholder="What's on your mind?"></textarea>
            </div>
            <button type="button" class="btn btn-primary" id="contact-send">Send message</button>
          </form>
          <p class="form-note">Submissions open your email client and send to {CONTACT_EMAIL}. No data is stored on our servers.</p>
        </div>
        <aside class="contact-sidebar">
          <div class="info-block">
            <h3>Email directly</h3>
            <p style="margin: 0; font-size: 0.9rem;">Prefer to skip the form:</p>
            <a href={`mailto:${CONTACT_EMAIL}`} style="margin-top: 0.5rem; display: inline-block; font-weight: 600;">{CONTACT_EMAIL}</a>
          </div>
          <div class="info-block">
            <h3>What we can help with</h3>
            <ul style="margin: 0; padding-left: 1.2rem; font-size: 0.875rem;">
              <li>Data corrections or questions</li>
              <li>Suggestions for the site</li>
              <li>Partnership or press inquiries</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </main>
</BaseLayout>

<script define:vars={{ CONTACT_EMAIL }}>
  (function () {
    const form = document.getElementById('contact-form');
    const btn = document.getElementById('contact-send');
    if (!form || !btn) return;
    btn.addEventListener('click', function () {
      const nameEl = form.querySelector('[name="name"]');
      const emailEl = form.querySelector('[name="email"]');
      const messageEl = form.querySelector('[name="message"]');
      const name = (nameEl && nameEl.value) ? nameEl.value.trim() : '';
      const email = (emailEl && emailEl.value) ? emailEl.value.trim() : '';
      const message = (messageEl && messageEl.value) ? messageEl.value.trim() : '';
      if (!name || !email || !message) {
        form.reportValidity();
        return;
      }
      const subject = 'StateWages contact from ' + (name || 'Someone');
      const body = 'From: ' + email + '\n\n' + message;
      const mailto = 'mailto:' + CONTACT_EMAIL + '?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
      window.location.href = mailto;
    });
  })();
</script>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 2.5rem;
    align-items: start;
    padding: 2rem 0 5rem;
  }
  .contact-form-wrap {
    max-width: 480px;
  }
  .contact-form .form-group {
    margin-bottom: 1.25rem;
  }
  .contact-form label {
    display: block;
    font-weight: 500;
    font-size: 0.875rem;
    margin-bottom: 0.35rem;
    color: var(--text);
  }
  .contact-form input,
  .contact-form textarea {
    width: 100%;
    padding: 0.6rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-family: var(--font);
    font-size: 0.95rem;
    color: var(--text);
    background: var(--white);
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--primary);
  }
  .contact-form textarea {
    resize: vertical;
    min-height: 120px;
  }
  .contact-form button {
    margin-top: 0.25rem;
  }
  .form-note {
    font-size: 0.8rem;
    color: var(--text-faint);
    margin-top: 1rem;
  }
  .contact-sidebar {
    position: sticky;
    top: calc(58px + 1rem);
  }
  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
    .contact-sidebar {
      position: static;
    }
  }
</style>
