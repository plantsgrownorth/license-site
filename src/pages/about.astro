---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const title = 'About Business License Guide - Our Mission & Methodology';
const description =
  'Learn about Business License Guide: our mission to make business licensing requirements accessible, how we research our data, and how to contribute.';
---

<BaseLayout title={title} description={description}>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'About' }]} />

  <div class="page-hero">
    <div class="container">
      <h1>About Business License Guide</h1>
      <p>Making business licensing requirements clear, accessible, and actionable for every entrepreneur.</p>
    </div>
  </div>

  <main>
    <div class="container">
      <div class="prose-content">
        <section class="section">
          <h2>Our Mission</h2>
          <p>
            Starting a business is hard enough without having to navigate confusing government websites,
            conflicting information, and unclear requirements. <strong>Business License Guide</strong> was
            created to solve that problem.
          </p>
          <p>
            We research official government sources, compile licensing requirements across all 50 U.S.
            states, and present the information in a clear, step-by-step format — so entrepreneurs
            can focus on building their business instead of drowning in bureaucracy.
          </p>
        </section>

        <section class="section">
          <h2>What We Cover</h2>
          <p>For each business type and state combination, we provide:</p>
          <ul>
            <li>The exact name of the required license or permit</li>
            <li>The issuing agency with a direct link to their website</li>
            <li>Application and renewal fees</li>
            <li>A complete list of required documents</li>
            <li>Prerequisites and eligibility requirements</li>
            <li>Estimated processing timelines</li>
            <li>Step-by-step application instructions</li>
            <li>Direct links to official application portals</li>
          </ul>
        </section>

        <section class="section">
          <h2>Our Research Methodology</h2>
          <p>
            All information on this site is sourced directly from official government websites,
            state agency publications, and legislative documents. We do not rely on third-party
            summaries or secondhand sources.
          </p>
          <p>
            Each license entry includes a "Last Verified" date indicating when we last confirmed
            the information against official sources. Requirements change frequently, so we
            recommend always verifying current requirements directly with the issuing agency
            before submitting any applications.
          </p>
        </section>

        <section class="section">
          <h2>Important Disclaimer</h2>
          <div class="disclaimer">
            <p>
              <strong>⚠️ Informational Use Only:</strong> Business License Guide provides general
              informational content only. Nothing on this website constitutes legal or professional
              advice. Licensing requirements change frequently. Always verify current requirements
              directly with the relevant government agency or consult a licensed attorney or
              business advisor before making decisions.
            </p>
          </div>
        </section>

        <section class="section">
          <h2>Contact & Contributions</h2>
          <p>
            Found outdated information? Know of a license type we haven't covered?
            We welcome corrections, updates, and suggestions from the community.
          </p>
          <p>
            <a href="/contact/" class="btn btn-primary">Contact Us</a>
          </p>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .prose-content {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 0;
  }
  .prose-content .section {
    margin-bottom: 2.5rem;
  }
</style>
