---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Salary Guides & Data Breakdowns — StateWages Blog';
const description = 'In-depth salary guides by occupation and state, built on official BLS data. No fluff, no surveys — just numbers and context.';

const postFiles = import.meta.glob('./*.md', { eager: true });
const posts = Object.entries(postFiles).map(([path, mod]: [string, any]) => ({
  ...mod,
  slug: path.replace('./', '').replace('.md', ''),
  url: '/blog/' + path.replace('./', '').replace('.md', '') + '/',
}));
const sorted = posts
  .sort((a, b) => new Date(b.frontmatter.date).getTime() - new Date(a.frontmatter.date).getTime());
---

<BaseLayout title={title} description={description}>
  <div class="page-hero">
    <div class="container">
      <span class="eyebrow">StateWages</span>
      <h1>Salary Guides</h1>
      <p>Deep dives into occupation pay, state comparisons, and wage trends — all sourced from BLS data.</p>
    </div>
  </div>

  <main>
    <div class="container" style="padding-top: 2rem; padding-bottom: 5rem; max-width: 760px;">
      {sorted.length === 0 ? (
        <p style="color: var(--text-muted); padding: 3rem 0;">Posts coming soon.</p>
      ) : (
        <div class="post-list">
          {sorted.map((post) => (
            <a href={post.url} class="post-card">
              <div class="post-date">
                {new Date(post.frontmatter.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </div>
              <h2 class="post-title">{post.frontmatter.title}</h2>
              <p class="post-desc">{post.frontmatter.description}</p>
              <span class="post-link">Read →</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
</BaseLayout>

<style>
  .post-list { display: flex; flex-direction: column; gap: 0; }

  .post-card {
    display: block;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
  }
  .post-card:first-child { border-top: 1px solid var(--border); }
  .post-card:hover .post-title { color: var(--primary-dark); }

  .post-date { font-size: 0.75rem; color: var(--text-faint); margin-bottom: 0.4rem; font-family: var(--font-mono); }
  .post-title { font-size: 1.15rem; color: var(--text); margin-bottom: 0.4rem; line-height: 1.3; transition: color 0.12s; }
  .post-desc { font-size: 0.875rem; color: var(--text-muted); line-height: 1.65; margin-bottom: 0.6rem; }
  .post-link { font-size: 0.82rem; font-weight: 600; color: var(--primary); }
</style>
