---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import businessTypes from '../../data/business-types.json';
import statesData from '../../data/states.json';

export async function getStaticPaths() {
  const licenseFiles = import.meta.glob('../../data/licenses/*.json', { eager: true });

  // Build a map: businessTypeSlug -> array of { state, license }
  const byType: Record<string, Array<{ stateSlug: string; stateName: string; stateAbbr: string; license: any }>> = {};

  for (const [, module] of Object.entries(licenseFiles)) {
    const data = (module as { default: any }).default;
    for (const license of data.licenses) {
      if (!byType[license.businessTypeSlug]) {
        byType[license.businessTypeSlug] = [];
      }
      byType[license.businessTypeSlug].push({
        stateSlug: data.stateSlug,
        stateName: data.state,
        stateAbbr: data.stateAbbreviation,
        license,
      });
    }
  }

  return businessTypes.map((bt) => ({
    params: { businessType: bt.slug },
    props: {
      businessType: bt,
      stateEntries: byType[bt.slug] ?? [],
      allStates: statesData,
    },
  }));
}

interface Props {
  businessType: { name: string; slug: string; description: string };
  stateEntries: Array<{ stateSlug: string; stateName: string; stateAbbr: string; license: any }>;
  allStates: Array<{ name: string; abbreviation: string; slug: string }>;
}

const { businessType, stateEntries, allStates } = Astro.props;

const coveredSlugs = new Set(stateEntries.map((e) => e.stateSlug));
const uncoveredStates = allStates.filter((s) => !coveredSlugs.has(s.slug));

const title = `${businessType.name} License Requirements by State (2026)`;
const description = `Compare ${businessType.name.toLowerCase()} license requirements across all 50 states. Find fees, required documents, issuing agencies, and application steps for every state.`;

const pageUrl = `https://businesslicenseguide.com/licenses/${businessType.slug}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: pageUrl,
};
---

<BaseLayout title={title} description={description} canonicalUrl={pageUrl} jsonLd={jsonLd}>
  <Breadcrumbs
    items={[
      { label: 'Home', href: '/' },
      { label: 'Licenses by Type', href: '/licenses/' },
      { label: businessType.name },
    ]}
  />

  <div class="page-hero">
    <div class="container">
      <div class="hero-eyebrow">Business Type Guide</div>
      <h1>{businessType.name} License Requirements</h1>
      <p>{businessType.description}</p>
      <div class="page-hero-meta">
        {stateEntries.length > 0 && (
          <span class="badge">✅ {stateEntries.length} states with full data</span>
        )}
        <span class="badge">🗺️ All 50 states listed</span>
      </div>
    </div>
  </div>

  <main>
    <div class="container">

      {stateEntries.length > 0 && (
        <section class="section" style="margin-top: 2rem;">
          <div class="section-heading">
            <h2>States with Full License Data</h2>
            <span class="section-count">{stateEntries.length} states</span>
          </div>

          <!-- Fee comparison table -->
          <div class="table-wrap">
            <table class="data-table">
              <thead>
                <tr>
                  <th>State</th>
                  <th>License Name</th>
                  <th>Issuing Agency</th>
                  <th>Application Fee</th>
                  <th>Renewal</th>
                  <th>Details</th>
                </tr>
              </thead>
              <tbody>
                {stateEntries.map((entry) => (
                  <tr>
                    <td>
                      <a href={`/${entry.stateSlug}/`} class="state-link">
                        <strong>{entry.stateAbbr}</strong>
                        <span>{entry.stateName}</span>
                      </a>
                    </td>
                    <td>{entry.license.licenseName}</td>
                    <td>{entry.license.issuingAgency}</td>
                    <td>{entry.license.applicationFee}</td>
                    <td>{entry.license.renewalPeriod}</td>
                    <td>
                      <a
                        href={`/${entry.stateSlug}/${businessType.slug}/`}
                        class="btn btn-outline"
                        style="padding: 0.3rem 0.75rem; font-size: 0.82rem;"
                      >
                        View Guide
                      </a>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      {uncoveredStates.length > 0 && (
        <section class="section">
          <h2 style="font-size: 1.1rem; margin-bottom: 1rem;">
            Coming Soon — {uncoveredStates.length} More States
          </h2>
          <div class="coming-grid">
            {uncoveredStates.map((state) => (
              <div class="coming-item">
                <span class="state-abbr">{state.abbreviation}</span>
                <span class="state-name">{state.name}</span>
              </div>
            ))}
          </div>
          <p class="coming-note">
            We're actively researching and adding data for all states.
            <a href="/contact/">Request a state</a> to prioritize it.
          </p>
        </section>
      )}

      <Disclaimer />
    </div>
  </main>
</BaseLayout>

<style>
  .hero-eyebrow {
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.75);
    margin-bottom: 0.6rem;
  }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .data-table { margin: 0; }

  .state-link {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    text-decoration: none;
  }
  .state-link strong {
    color: var(--color-primary);
    font-size: 0.9rem;
  }
  .state-link span {
    color: var(--color-text-muted);
    font-size: 0.78rem;
  }

  .coming-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .coming-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  .coming-note {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
  }
</style>
