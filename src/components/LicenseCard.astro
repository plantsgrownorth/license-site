---
interface Props {
  licenseName: string;
  businessType: string;
  businessTypeSlug: string;
  issuingAgency: string;
  applicationFee: string;
  renewalPeriod: string;
  stateSlug: string;
}

const {
  licenseName,
  businessType,
  issuingAgency,
  applicationFee,
  renewalPeriod,
  stateSlug,
  businessTypeSlug,
} = Astro.props;
---

<a href={`/${stateSlug}/${businessTypeSlug}/`} class="license-card">
  <div class="license-card-title">{licenseName}</div>
  <div class="license-card-agency">{issuingAgency}</div>
  <div class="license-card-meta">
    <span class="tag">💰 {applicationFee}</span>
    <span class="tag">🔄 {renewalPeriod}</span>
  </div>
</a>
