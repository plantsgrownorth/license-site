---
import statesData from '../data/states.json';

interface Props {
  heading?: string;
  showHeading?: boolean;
}

const { heading = 'Browse by State', showHeading = true } = Astro.props;
---

<section id="states" class="section">
  {showHeading && (
    <div class="section-heading">
      <h2>{heading}</h2>
      <span class="section-count">{statesData.length} states</span>
    </div>
  )}
  <div class="state-grid">
    {statesData.map((state) => (
      <a href={`/${state.slug}/`} class="state-card">
        <span class="state-abbr">{state.abbreviation}</span>
        <span class="state-name">{state.name}</span>
      </a>
    ))}
  </div>
</section>
